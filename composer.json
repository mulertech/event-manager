{
  "name": "mulertech/event-manager",
  "description": "This package manage events in your application",
  "type": "library",
  "keywords": [
    "php",
    "event",
    "dispatcher",
    "psr-14"
  ],
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "Sébastien Muler",
      "email": "sebastien.muler@mulertech.net"
    }
  ],
  "require": {
    "php": "^8.4",
    "psr/event-dispatcher": "^1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.6",
    "mulertech/docker-dev": "^3.2",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "MulerTech\\EventManager\\": "./src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MulerTech\\EventManager\\Tests\\": "./tests"
    }
  },
  "config": {
    "sort-packages": true
  }
}
